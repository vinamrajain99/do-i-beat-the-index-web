# Copy this to .env.local and fill in your real values from:
# Supabase Dashboard → Project Settings → API

# Public — sent to the browser. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Secret — server-only. Used by the Python analysis function to bypass RLS
# when writing benchmark price cache and reading any user's CSV from storage.
# NEVER prefix with NEXT_PUBLIC_, never log, never commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL. Used to build email confirmation / password reset links.
# Use http://localhost:3000 for local dev; the Vercel deploy URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
